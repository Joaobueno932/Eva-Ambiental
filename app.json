{
  "expo": {
    "name": "Eva Ambiental",
    "slug": "eva-ambiental",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "evaambiental",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF8E7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.evaambiental.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#63B32E"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "O Eva Ambiental precisa da câmera para registrar fotos das pesagens."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O Eva Ambiental precisa acessar suas fotos para anexar evidências de pesagens."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O Eva Ambiental usa sua localização para registrar onde a pesagem foi feita."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
